  [1m[36mAbout Create (0.3ms)[0m  [1m[32mINSERT INTO "abouts" ("body", "created_at", "lead", "signature", "studio", "title", "updated_at") VALUES (NULL, '2026-06-08 05:15:26.873836', 'Preciso is the porcelain studio of Bianna Taynova.', 'Bianna Taynova', 'Studio Preciso · by appointment', 'From a small studio, one piece at a time', '2026-06-08 05:15:26.873836') RETURNING "id" /*application='Precisodesign'*/[0m
  ↳ app/models/about.rb:6:in 'About.instance'
  [1m[36mTRANSACTION (0.0ms)[0m  [1m[35mCOMMIT TRANSACTION /*application='Precisodesign'*/[0m
