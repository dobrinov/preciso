  [1m[36mAbout Create (0.3ms)[0m  [1m[32mINSERT INTO "abouts" ("title", "lead", "body", "signature", "studio", "created_at", "updated_at") VALUES ('From a small studio, one piece at a time', 'Preciso is the porcelain studio of Bianna Taynova.', NULL, 'Bianna Taynova', 'Studio Preciso · by appointment', '2026-06-08 04:51:14.344749', '2026-06-08 04:51:14.344749') RETURNING "id" /*application='Precisodesign'*/[0m
