<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Preciso — Studio Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if session[:admin] %>
      <div class="admin">
        <%= render "admin/shared/sidebar" %>
        <div class="admin-main"><%= yield %></div>
      </div>
    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>
