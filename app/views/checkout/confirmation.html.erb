<main class="wrap fade-up confirm">
  <div class="confirm-inner">
    <div class="confirm-check">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M5 13l4 4L19 7"/></svg>
    </div>
    <div class="eyebrow clay" style="margin-top:24px">Order received</div>
    <h1 class="display confirm-title">Thank you, <%= @order.customer_name.to_s.split(" ").first %></h1>
    <p class="confirm-lead">
      Your order <span class="mono clay-text"><%= @order.number %></span> is with the studio. Bianna will email you at
      <strong><%= @order.customer_email %></strong> to confirm the pieces and arrange payment and pickup.
    </p>
  </div>

  <div class="confirm-summary">
    <div class="confirm-summary-head">
      <span>Summary</span><span class="mono"><%= date_label @order.created_at %></span>
    </div>
    <% @order.order_lines.each do |l| %>
      <div class="confirm-line">
        <span><%= l.display_name %> <span style="color:var(--muted)">× <%= l.qty %></span></span>
        <span class="serif" style="font-size:16px"><%= money l.subtotal %></span>
      </div>
    <% end %>
    <div style="display:flex;justify-content:space-between;padding:16px 24px;align-items:baseline">
      <span class="cart-total-label">Total</span>
      <span class="serif" style="font-size:28px"><%= money @order.total %></span>
    </div>
  </div>

  <div style="text-align:center;margin-top:36px">
    <a href="<%= root_path %>" class="btn ghost">Back to home</a>
  </div>
</main>
