<main class="wrap fade-up page-top">
  <%= render "shared/breadcrumb", trail: [[@category&.name || "Shop", @category ? shop_category_path(@category.slug) : nil], [@product.name, nil]] %>
  <%
    has_variants = @product.has_variants?
    # Initial gallery: the first variation that has photos, else the product's
    # own photos. The variant switcher (JS) swaps these to the selected
    # variation's photos on the client, falling back to the product's.
    gallery_imgs =
      if has_variants
        (@variants.detect { |v| v.images.attached? }&.ordered_images) || (@product.images.attached? ? @product.ordered_images : [])
      elsif @product.images.attached?
        @product.ordered_images
      else
        []
      end

    if has_variants
      # Attributes this product's variants use, ordered, each with its distinct values.
      product_attrs = @variants.flat_map(&:variant_attribute_values).uniq
                               .group_by(&:variant_attribute)
                               .sort_by { |attr, _| attr.position }
                               .map { |attr, vals| [ attr, vals.uniq.sort_by(&:position) ] }
      default_value_ids = @variants.first.variant_attribute_value_ids
      # Map keyed by each variant's sorted value-ids; the dropdowns resolve a
      # selection to a variant client-side. priceLabel HTML rides through to_json
      # (which escapes < as <, not the \/ that escape_javascript produces).
      variant_map = @variants.each_with_object({}) do |v, h|
        cur  = v.current_price_via_product
        base = v.price
        urls = v.images.attached? ? v.ordered_images.map { |i| url_for(i) } : (@product.images.attached? ? @product.ordered_images.map { |i| url_for(i) } : [])
        h[v.variant_attribute_value_ids.sort.join("-")] = {
          variantId:  v.id,
          pricePlain: money(cur),
          priceLabel: (cur < base ? "<span class='price-now'>#{money cur}</span> <span class='price-was'>#{money base}</span>" : money(cur)),
          images:     urls
        }
      end
    end
  %>
  <div class="detail-grid" data-controller="variants" <% if has_variants %>data-variants-map="<%= variant_map.to_json %>"<% end %>>
    <div class="detail-media" data-controller="gallery">
      <div class="detail-media-frame">
        <% if gallery_imgs.any? %>
          <div class="ratio-box" style="padding-top:120%">
            <%= image_tag gallery_imgs.first, alt: @product.name, class: "cover-img", data: { gallery_target: "main", variants_target: "mainImage" } %>
          </div>
        <% else %>
          <%= media_for(@product, kind: "product", ratio: "120%") %>
        <% end %>
      </div>
      <% if gallery_imgs.any? && (has_variants || gallery_imgs.size > 1) %>
        <div class="gallery-thumbs" data-variants-target="thumbs">
          <% gallery_imgs.each_with_index do |img, i| %>
            <button type="button" class="gallery-thumb <%= 'active' if i.zero? %>"
                    data-action="gallery#show" data-gallery-target="thumb" data-src="<%= url_for(img) %>">
              <%= image_tag img, alt: "#{@product.name} photo #{i + 1}", class: "cover-img" %>
            </button>
          <% end %>
        </div>
      <% end %>
    </div>
    <div style="padding-top:6px">
      <div class="eyebrow clay"><%= @category&.name %></div>
      <h1 class="display detail-title"><%= @product.name %></h1>
      <div class="detail-price" data-variants-target="price">
        <% if has_variants %><%= price_tag(@product, variant: @variants.first) %><% else %><%= price_tag(@product) %><% end %>
      </div>
      <% if has_variants %>
        <div class="variant-unavailable" data-variants-target="unavailable" hidden>This combination isn't available.</div>
      <% end %>
      <p class="detail-long"><%= @product.long_desc %></p>

      <% if has_variants %>
        <div class="variant-pick">
          <% product_attrs.each do |attr, values| %>
            <label class="variant-field">
              <span class="variant-field-label"><%= attr.name %></span>
              <select class="variant-select" data-variants-target="attrSelect" data-action="change->variants#select">
                <% values.each do |val| %>
                  <option value="<%= val.id %>" <%= "selected" if default_value_ids.include?(val.id) %>><%= val.value %></option>
                <% end %>
              </select>
            </label>
          <% end %>
        </div>
      <% end %>

      <div class="detail-actions">
        <%= form_with url: cart_add_path, data: { turbo_stream: true } do %>
          <input type="hidden" name="kind" value="product">
          <input type="hidden" name="id" value="<%= @product.id %>">
          <input type="hidden" name="name" value="<%= @product.name %>">
          <% if has_variants %>
            <input type="hidden" name="variant_id" value="<%= @variants.first&.id %>" data-variants-target="variantId">
          <% end %>
          <button type="submit" class="btn clay" style="width:100%;padding:17px 30px" data-variants-target="addButton">
            <%= icon :cart %> <span data-variants-target="addLabel">Add — <%= money(has_variants ? @variants.first&.current_price_via_product : @product.current_price) %></span>
          </button>
        <% end %>
      </div>
      <div class="detail-notes">
        <span>· Made to order in small batches</span>
        <span>· Arrange payment &amp; pickup after</span>
      </div>
    </div>
  </div>

  <% if @related.any? %>
    <section style="margin-top:100px">
      <div class="section-head">
        <h2 class="display" style="font-size:34px">More <%= @category.name.downcase %></h2>
        <a href="<%= shop_category_path(@category.slug) %>" class="link-underline">View all <%= icon :arrow, size: 16 %></a>
      </div>
      <div class="grid-4">
        <% @related.each do |p| %>
          <%= render "shared/product_card", record: p, kind: "product" %>
        <% end %>
      </div>
    </section>
  <% end %>
</main>
