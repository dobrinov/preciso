<% content_for :title, "Preciso — Vacation" %>
<%= form_with url: admin_vacation_path, method: :patch, data: { turbo: false } do %>
  <div class="pagehead">
    <div>
      <h1 class="display pagehead-title">Vacation</h1>
      <p class="pagehead-sub">Warn customers about slower order processing before they check out.</p>
    </div>
    <div class="pagehead-actions">
      <button type="submit" class="btn clay sm"><%= icon :check, size: 16 %> Save</button>
    </div>
  </div>

  <div class="admin-pad" style="max-width:640px">
    <div class="card-pad">
      <% if flash[:notice] %>
        <div class="flash-saved fade-up"><%= icon :check, size: 16 %> Saved</div>
      <% end %>

      <label class="field" style="flex-direction:row;align-items:center;gap:10px">
        <%= check_box_tag :active, "1", @vacation.active %>
        <div class="field-label" style="margin:0">On — show a confirmation about slower processing at checkout</div>
      </label>

      <label class="field"><div class="field-label">Message</div>
        <%= text_area_tag :message, @vacation.message, rows: 4, class: "input" %>
        <div class="field-hint">Shown in the confirmation modal when a customer places an order while this is on.</div>
      </label>

      <div>
        <button type="submit" class="btn clay"><%= icon :check, size: 16 %> Save changes</button>
      </div>
    </div>
  </div>
<% end %>
