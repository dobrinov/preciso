<% is_new = @product.new_record? %>
<div class="pagehead">
  <div>
    <h1 class="display pagehead-title"><%= is_new ? "New piece" : (@product.name.presence || "Edit piece") %></h1>
    <p class="pagehead-sub"><%= is_new ? "Add a piece to the catalogue." : "Editing an existing piece." %></p>
  </div>
  <div class="pagehead-actions">
    <a href="<%= admin_products_path %>" class="btn ghost sm"><%= icon :back, size: 16 %> Back</a>
  </div>
</div>

<%= form_with model: [:admin, @product], html: { multipart: true } do |f| %>
  <div class="admin-pad editor-grid">
    <div class="card-pad">
      <label class="field">
        <div class="field-label">Name</div>
        <%= f.text_field :name, class: "input", placeholder: "e.g. Morning Cup" %>
      </label>
      <div class="row-2">
        <label class="field">
          <div class="field-label">Category</div>
          <%= f.collection_select :category_id, Category.all, :id, :name, { include_blank: "Uncategorised" }, class: "input" %>
        </label>
        <% if @product.has_variants? %>
          <div class="field">
            <div class="field-label">Price (€)</div>
            <div class="input" style="display:flex;align-items:center;color:var(--muted)">Set per variation — from <%= money @product.price_from %></div>
            <div class="field-hint">This piece is priced by its variations below.</div>
          </div>
        <% else %>
          <label class="field">
            <div class="field-label">Price (€)</div>
            <%= f.number_field :price, min: 1, class: "input", placeholder: "e.g. 40", required: true %>
            <div class="field-hint">Required. Add variations on the right for multiple priced options instead.</div>
          </label>
        <% end %>
      </div>
      <label class="field">
        <div class="field-label">Short description</div>
        <%= f.text_field :short, class: "input", placeholder: "One quiet line about the piece." %>
        <div class="field-hint">Shown on cards and lists.</div>
      </label>
      <label class="field">
        <div class="field-label">Long description</div>
        <%= f.text_area :long_desc, rows: 5, class: "input", placeholder: "Materials, size, the making of it…" %>
        <div class="field-hint">Shown on the product page.</div>
      </label>
    </div>

    <div class="stack-18">
      <div class="box" data-controller="multiupload">
        <div class="box-label">Photographs</div>
        <div class="field-hint" style="margin-bottom:10px">Drag to reorder — the first photo is the cover. Marked photos are removed on save.</div>
        <div class="img-grid" data-multiupload-target="grid">
          <% @product.ordered_images.each do |img| %>
            <div class="img-tile" draggable="true" data-image-id="<%= img.id %>"
                 data-action="dragstart->multiupload#tileDragstart dragover->multiupload#tileDragover drop->multiupload#tileDrop dragend->multiupload#tileDragend">
              <%= image_tag img, class: "cover-img" %>
              <input type="checkbox" name="remove_image_ids[]" value="<%= img.id %>" class="img-remove-cb">
              <button type="button" class="img-remove-x" data-action="multiupload#toggleRemove" title="Remove"><%= icon :close, size: 14 %></button>
            </div>
          <% end %>
        </div>

        <div class="dropzone dz-multi" data-multiupload-target="zone" data-action="click->multiupload#browse dragover->multiupload#zoneDragover dragleave->multiupload#zoneDragleave drop->multiupload#zoneDrop">
          <div><%= placeholder(tone: @product.tone, name: "Add photos", caption: "click or drop photos") %></div>
        </div>
        <%= f.file_field :images, multiple: true, accept: "image/*", style: "display:none", data: { multiupload_target: "input", action: "multiupload#changed" } %>
        <%= hidden_field_tag "image_order_tokens", "", data: { multiupload_target: "order" } %>
        <div class="dropzone-actions">
          <button type="button" class="btn ghost sm" style="flex:1" data-action="multiupload#browse">Add photos</button>
        </div>
      </div>

      <div class="box">
        <div class="box-label">Variations</div>
        <% if is_new %>
          <div class="field-hint">Save the piece first, then add variations.</div>
        <% else %>
          <% if @product.variants.any? %>
            <div class="admin-list" style="margin-bottom:12px">
              <% @product.variants.each do |v| %>
                <a href="<%= edit_admin_product_variant_path(@product, v) %>" class="admin-row" style="padding:10px 12px">
                  <div class="admin-row-thumb" style="width:42px;height:42px">
                    <% if v.primary_image %><%= image_tag v.primary_image, class: "cover-img" %><% else %><%= placeholder(tone: @product.tone) %><% end %>
                  </div>
                  <div class="admin-row-main"><div class="admin-row-name"><%= v.label.presence || "Variation ##{v.id}" %></div><div class="admin-row-sub"><%= money v.price %></div></div>
                  <span class="admin-row-go"><%= icon :edit, size: 16 %></span>
                </a>
              <% end %>
            </div>
          <% else %>
            <div class="field-hint" style="margin-bottom:12px">No variations — this piece sells as a single option using the price and photos above.</div>
          <% end %>
          <a href="<%= new_admin_product_variant_path(@product) %>" class="btn ghost sm"><%= icon :plus, size: 16 %> Add variation</a>
        <% end %>
      </div>

      <div class="box" style="display:flex;flex-direction:column;gap:12px">
        <%= f.submit (is_new ? "Add piece" : "Save changes"), class: "btn clay" %>
        <% unless is_new %>
          <%# Delete is a Turbo link, not a nested <form> — it sits beside Save without breaking the edit form. %>
          <%= link_to admin_product_path(@product), class: "danger-btn", data: { turbo_method: :delete, turbo: true, turbo_confirm: "Delete this piece? It will be removed from any sets." } do %>
            <%= icon :trash, size: 16 %> Delete piece
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
