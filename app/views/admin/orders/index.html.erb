<% content_for :title, "Preciso — Orders" %>
<div class="pagehead">
  <div>
    <h1 class="display pagehead-title">Orders</h1>
    <p class="pagehead-sub">Orders placed from the storefront arrive here.</p>
  </div>
</div>

<div class="filter-bar">
  <% (["all"] + Order::STATUS_ORDER).each do |s| %>
    <% label = s == "all" ? "All" : Order::STATUSES[s][:label] %>
    <a href="<%= admin_orders_path(filter: s) %>" class="filter-btn <%= 'active' if @filter == s %>">
      <%= label %> <span class="ct"><%= @counts[s] %></span>
    </a>
  <% end %>
</div>

<div class="admin-pad">
  <div class="ord-table">
    <div class="ord-head">
      <div>Order</div><div>Customer</div><div>Placed</div><div>Status</div><div class="text-right">Total</div>
    </div>
    <% if @orders.empty? %>
      <div class="empty-state">No orders here yet.</div>
    <% end %>
    <% @orders.each do |o| %>
      <a href="<%= admin_order_path(o) %>" class="ord-row">
        <div class="ord-num"><%= o.number %></div>
        <div style="min-width:0">
          <div class="ord-customer"><%= o.customer_name %></div>
          <div class="ord-items"><%= o.order_lines.map { |l| l.name + (l.qty > 1 ? " ×#{l.qty}" : "") }.join(", ") %></div>
        </div>
        <div class="ord-date"><%= time_ago o.created_at %></div>
        <div><%= render "admin/shared/status_pill", status: o.status %></div>
        <div class="ord-total"><%= money o.total %></div>
      </a>
    <% end %>
  </div>
</div>
