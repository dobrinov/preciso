<%
  # Per-page overrides (@meta_*) set by show actions; otherwise the home-page brand card.
  default_title = [ home_page.hero_title.to_s.split("\n").join(" "), home_page.hero_accent ].reject(&:blank?).join(" ").strip
  title = @meta_title.presence || default_title
  desc  = @meta_description.presence || home_page.hero_subtext.to_s
  type  = @meta_type.presence || "website"
  custom_image = og_image?(@meta_image)
  image = og_image_url(@meta_image)
%>
<meta name="description" content="<%= desc %>">
<link rel="canonical" href="<%= canonical_url %>">
<% if @noindex %><meta name="robots" content="noindex"><% end %>
<meta property="og:type" content="<%= type %>">
<meta property="og:site_name" content="Preciso">
<meta property="og:title" content="<%= title %>">
<meta property="og:description" content="<%= desc %>">
<meta property="og:url" content="<%= canonical_url %>">
<meta property="og:image" content="<%= image %>">
<% if custom_image %>
  <meta property="og:image:alt" content="<%= title %>">
<% else %>
  <meta property="og:image:width" content="1050">
  <meta property="og:image:height" content="600">
  <meta property="og:image:alt" content="Preciso">
<% end %>
<% if @meta_price.present? %>
  <meta property="product:price:amount" content="<%= @meta_price %>">
  <meta property="product:price:currency" content="EUR">
<% end %>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= title %>">
<meta name="twitter:description" content="<%= desc %>">
<meta name="twitter:image" content="<%= image %>">
